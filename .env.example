# --- LLM routing ---
# OpenRouter powers every LLM call that does not need a specific engine
# (classification, message generation, reply classification, report copy).
OPENROUTER_API_KEY=

# OpenAI is used ONLY for the ChatGPT visibility probe (must hit the real engine).
OPENAI_API_KEY=

# --- Visibility probes ---
# SerpAPI for Google AI Overviews.
SERPAPI_KEY=
# Perplexity is probed via OpenRouter sonar models, so no separate key needed,
# but set this if you prefer to hit Perplexity directly.
PERPLEXITY_API_KEY=

# --- Prospecting and enrichment ---
APIFY_TOKEN=
COMPANIES_HOUSE_API_KEY=

# --- Postal channel ---
STANNP_API_KEY=

# --- Airtable import ---
AIRTABLE_API_KEY=
AIRTABLE_BASE_ID=

# Short URL base for letter claim links, e.g. https://antek.link
# Letters render a QR code and short URL as CLAIM_BASE_URL/{claim_code}.
CLAIM_BASE_URL=https://antek.link
