# --- LLM routing + visibility probes ---
# OpenRouter powers every LLM call (classification, message generation, reply
# classification, report copy) AND the four visibility flagships (ChatGPT,
# Claude, Gemini, Perplexity). One key does all of it. Required.
OPENROUTER_API_KEY=

# --- Visibility probes ---
# SerpAPI for the Google AI Overview probe (the 5th engine in the hybrid check).
# Optional: without it the check runs on the four OpenRouter engines only.
SERPAPI_KEY=

# --- Prospecting and enrichment ---
APIFY_TOKEN=
COMPANIES_HOUSE_API_KEY=

# --- Postal channel ---
STANNP_API_KEY=

# --- Airtable import ---
AIRTABLE_API_KEY=
AIRTABLE_BASE_ID=

# Short URL base for letter claim links, e.g. https://antek.link
# Letters render a QR code and short URL as CLAIM_BASE_URL/{claim_code}.
CLAIM_BASE_URL=https://antek.link
